# ============================================================
# ローカル開発 (docker-compose)
# ============================================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# Google Maps APIキー（任意 — 未設定時は Nominatim を自動使用）
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================
# クラウドデプロイ用（Render + Supabase + Vercel）
# ============================================================

# --- Render (backend) に設定する環境変数 ---
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# GOOGLE_MAPS_API_KEY=your_key
# PORT=3001

# --- Vercel (frontend) に設定する環境変数 ---
# API_URL=https://your-backend-name.onrender.com
#   ※ NEXT_PUBLIC_ を付けないこと（サーバーサイド専用）
